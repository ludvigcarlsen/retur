<?xml version="1.0" encoding="utf-8"?>
<!--
  Bare Chronometer embedded into the Glance widgets via AndroidRemoteViews.
  Glance has no native ticking timer; a Chronometer counts down on the system
  clock with zero widget refreshes - the Android analog of iOS Text(style: .timer).
-->
<Chronometer xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_chronometer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:textColor="#FFFFFF"
    android:textStyle="bold"
    android:textSize="14sp" />
